{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    {
      "source": "/pharma/(.*)",
      "destination": "/PHARMA_ENGINE/API/indexnew.py"
    },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python",
      "memory": 1024,
      "maxDuration": 60
    },
    "PHARMA_ENGINE/API/indexnew.py": {
      "runtime": "@vercel/python",
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
