{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/pharma/(.*)", "destination": "/api/pharma.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/*.py": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
