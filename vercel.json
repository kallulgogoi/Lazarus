{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "PHARMA_ENGINE/API/indexnew.py", "use": "@vercel/python" },
    { "src": "package.json", "use": "@vercel/static-build" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    {
      "source": "/pharma/(.*)",
      "destination": "PHARMA_ENGINE/API/indexnew.py"
    },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python",
      "memory": 1024,
      "maxDuration": 60
    },
    "PHARMA_ENGINE/API/indexnew.py": {
      "runtime": "@vercel/python",
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
