{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "PHARMA_ENGINE/API/indexnew.py",
      "use": "@vercel/python"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/pharma/(.*)",
      "dest": "PHARMA_ENGINE/API/indexnew.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
